*** Settings ***Library     SeleniumLibrary*** Variables ***${browser}  chrome${URL}      https://www.saucedemo.com/${username}     standard_user${password}     secret_sauce*** Test Cases ***TestC-SD-Login    Open Browser    ${URL}    ${browser}    options=add_argument("--incognito"); add_argument("--disable-notifications")    Sleep           1 seconds    Input Text      id=user-name    ${username}    Input Password  name=password   ${password}    Click Button    id=login-button    Element Should Be Visible   class:title    Element Text Should Be      class:title     Products    Close BrowserTestC-SD-Login_User_Bloqueado    Open Browser    ${URL}    ${browser}    options=add_argument("--incognito"); add_argument("--disable-notifications")    Sleep           1 seconds    Input Text      id=user-name    locked_out_user    Input Password  name=password   ${password}    Click Button    id=login-button    Page Should Contain     Sorry, this user has been locked out    Close BrowserTestC-SD-Validar_Total_Con_Impuestos    Open Browser    ${URL}    ${browser}    options=add_argument("--incognito"); add_argument("--disable-notifications")    Sleep           1 seconds    Input Text      id=user-name    ${username}    Input Password  name=password   ${password}    Click Button    id=login-button    Click Button    name=add-to-cart-sauce-labs-backpack    Click Link      class=shopping_cart_link    Click Button    id=checkout    Input Text      id=first-name   Pedrito    Input Text      id=last-name    Sola    Input Text      id=postal-code  1234    Click Button    id=continue    Page Should Contain     Tax:    Element Text Should Be  class=summary_total_label   Total: $32.39    Close BrowserTestC-SD-Agregar_Producto_Carrito    Open Browser    ${URL}    ${browser}    options=add_argument("--incognito"); add_argument("--disable-notifications")    Sleep           1 seconds    Input Text      id=user-name    ${username}    Input Password  name=password   ${password}    Click Button    id=login-button    Click Button    name=add-to-cart-sauce-labs-backpack    Element Text Should Be    class=shopping_cart_badge    1    Click Link      class=shopping_cart_link    Page Should Contain     Sauce Labs Backpack    Close BrowserTestC-SD-Flujo_de_Compra    Open Browser    ${URL}    ${browser}    options=add_argument("--incognito"); add_argument("--disable-notifications")    Sleep           1 seconds    Input Text    id=user-name    ${username}    Input Password    name=password    ${password}    Click Button    id=login-button    Click Button    name=add-to-cart-sauce-labs-backpack    Click Link    class=shopping_cart_link    Click Button    id=checkout    Input Text    name=firstName    John    Input Text    name=lastName    Doe    Input Text    name=postalCode    12345    Click Button    id=continue    Click Button    id=finish    Page Should Contain    Thank you for your order!    Close BrowserTestC-SD-Persistencia_Carrito_Post_Logout    Open Browser    ${URL}    ${browser}    options=add_argument("--incognito"); add_argument("--disable-notifications")    Sleep           1 seconds    Input Text    id=user-name    ${username}    Input Password    name=password    ${password}    Click Button    id=login-button    Click Button    id=add-to-cart-sauce-labs-backpack    Click Button    id=react-burger-menu-btn    Wait Until Element Is Visible   id=logout_sidebar_link  5s    Click Link      id=logout_sidebar_link    Input Text    id=user-name    ${username}    Input Password    name=password    ${password}    Click Button    id=login-button    Element Text Should Be  class=shopping_cart_badge   1    Close BrowserTestC-SD-Login_con_Credenciales_Invalidas    Open Browser    ${URL}    ${browser}    options=add_argument("--incognito"); add_argument("--disable-notifications")    Sleep           1 seconds    Input Text    id=user-name    ${username}    Input Password    name=password    1234    Click Button    id=login-button    Page Should Contain    Username and password do not match any user in this service        Close BrowserTestC-SD-Acceso_no_Autorizado    Open Browser     https://www.saucedemo.com/inventory.html     ${browser}    Sleep           5 seconds    Page Should Contain     Epic sadface: You can only access '/inventory.html' when you are logged in.    Close BrowserTestC-SD-Campo_Vacio_Checkout    Open Browser    ${URL}    ${browser}    options=add_argument("--incognito"); add_argument("--disable-notifications")    Sleep           1 seconds    Input Text    id=user-name    ${username}    Input Password    name=password    ${password}    Click Button    id=login-button    Click Button    name=add-to-cart-sauce-labs-backpack    Click Link    class=shopping_cart_link    Click Button    id=checkout    Input Text    name=firstName    John    Input Text    name=lastName    Doe    Click Button    id=continue    Page Should Contain    Error: Postal Code is required    Close BrowserTestC-SD-Orden_de_Productos_HighToLow_Correcto    Open Browser    ${URL}    ${browser}    options=add_argument("--incognito"); add_argument("--disable-notifications")    Sleep           1 seconds    Input Text    id=user-name    ${username}    Input Password    name=password    ${password}    Click Button    id=login-button    Click Element    class=product_sort_container    Select From List By Value    class=product_sort_container    hilo    ${primer_precio}=    Get Text    xpath:(//div[@class="inventory_item_price"])[1]    Should Be Equal As Strings    ${primer_precio}    $49.99    Close Browser